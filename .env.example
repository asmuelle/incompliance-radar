# Which LLM backend the server uses: "ollama" (local, default) or "anthropic" (frontier).
LLM_BACKEND=ollama

# --- Ollama (local models) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Anthropic (frontier models) ---
# Required only when LLM_BACKEND=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
